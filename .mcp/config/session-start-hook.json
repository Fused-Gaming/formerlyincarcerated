{
  "name": "session-start-hook",
  "version": "1.0.0",
  "description": "Automatic session initialization hook for MCP framework",
  "trigger": "sessionStart",
  "enabled": true,
  "commands": [
    {
      "order": 1,
      "name": "check-package-updates",
      "command": "npm run mcp:check-updates",
      "failSilently": true,
      "timeout": 10000,
      "description": "Check for updates to @h4shed packages"
    },
    {
      "order": 2,
      "name": "verify-mcp-integrity",
      "command": "npm run mcp:init",
      "failSilently": false,
      "timeout": 15000,
      "description": "Verify MCP framework integrity and initialize"
    },
    {
      "order": 3,
      "name": "sync-skills",
      "command": "node .mcp/scripts/init-mcp.js",
      "failSilently": false,
      "timeout": 10000,
      "description": "Synchronize available skills"
    }
  ],
  "environment": {
    "NODE_ENV": "development",
    "MCP_DEBUG": false
  },
  "notifications": {
    "onSuccess": "MCP framework initialized successfully",
    "onFailure": "MCP initialization encountered errors - check logs",
    "verbose": false
  },
  "schedule": {
    "runOnSessionStart": true,
    "runOnSessionResume": true,
    "interval": null,
    "skipIfRecentlyRun": false,
    "recentThreshold": 3600000
  }
}
